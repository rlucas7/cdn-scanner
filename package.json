    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "babel-jest": "^30.1.2",
    "cosmiconfig": "^9.0.0",
    "jest": "^30.1.3",
    "jsdoc": "^4.0.4"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!yargs|yargs-parser)"
    ],
    "collectCoverage": true
